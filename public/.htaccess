Options +FollowSymLinks +ExecCGI
AddHandler wsgi-script .py
RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Set Python path and version
SetEnv PYTHONPATH /home/ddiemeo9zafc/mapcontacts
SetEnv FLASK_APP app.py
SetEnv FLASK_ENV production
SetEnv PYTHON_VERSION 3.7

# Handle static files
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Handle API routes
RewriteRule ^api/(.*)$ /app_wsgi.py/$1 [QSA,L]

# Handle frontend routes
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /app_wsgi.py/$1 [QSA,L]

# Allow access to all files
<Files *>
    Require all granted
</Files>

# Allow access to Python files
<FilesMatch "\.(py|wsgi)$">
    Require all granted
</FilesMatch>

# Allow access to static files
<FilesMatch "\.(css|js|jpg|jpeg|png|gif|ico|svg|woff|woff2|ttf|eot|html)$">
    Require all granted
</FilesMatch>

# Security headers
Header set X-Content-Type-Options "nosniff"
Header set X-Frame-Options "SAMEORIGIN"
Header set X-XSS-Protection "1; mode=block"
Header set Strict-Transport-Security "max-age=31536000; includeSubDomains" 